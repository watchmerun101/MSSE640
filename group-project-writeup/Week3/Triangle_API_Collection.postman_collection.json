    {
      "name": "08 - Error Example: Get Missing Triangle",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{url}}/triangles/999999",
          "host": [
            "{{url}}"
          ],
          "path": [
            "triangles",
            "999999"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "  pm.response.to.have.status(404);",
              "});",
              "pm.test('Error payload includes message and status', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('error');",
              "  pm.expect(body.status).to.eql(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "response": []
    },
